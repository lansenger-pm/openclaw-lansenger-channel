{
  "compilerOptions": {
    "outDir": "dist",
    "module": "esnext",
    "target": "es2022",
    "types": ["node"],
    "sourceMap": true,
    "declaration": false,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true
  }
}
