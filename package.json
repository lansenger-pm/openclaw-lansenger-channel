{
  "name": "@lansenger-pm/openclaw-lansenger-channel",
  "version": "3.13.2",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/index.*",
    "dist/setup-entry.*",
    "dist/src/channel.js",
    "dist/src/channel.d.ts",
    "dist/src/channel.js.map",
    "dist/src/client.js",
    "dist/src/client.d.ts",
    "dist/src/client.js.map",
    "dist/src/runtime.js",
    "dist/src/runtime.d.ts",
    "dist/src/runtime.js.map",
    "dist/src/setup-i18n.*",
    "dist/src/setup-wizard.js",
    "dist/src/setup-wizard.d.ts",
    "dist/src/setup-wizard.js.map",
    "dist/src/tools.js",
    "dist/src/tools.js.map",
    "dist/vitest.config.*",
    "skills/",
    "openclaw.plugin.json",
    "README.md",
    "README.zhHans.md",
    "README.zhHant.md",
    "README.zhHantHK.md",
    "README.fr.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "description": "Lansenger (蓝信) channel plugin for OpenClaw — WebSocket inbound, HTTP API outbound, text/markdown/media/linkCard/appCard/approval delivery",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lansenger-pm/openclaw-lansenger-channel.git"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "tsc && vitest run"
  },
  "keywords": [
    "openclaw",
    "channel",
    "lansenger",
    "蓝信",
    "enterprise-chat",
    "messaging",
    "approval",
    "appCard"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "runtimeSetupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "lansenger",
      "label": "Lansenger (蓝信)",
      "selectionLabel": "Lansenger (蓝信)",
      "detailLabel": "Lansenger Bot",
      "docsPath": "https://open.e.lanxin.cn/docs",
      "blurb": "Connect OpenClaw to Lansenger enterprise messaging platform. / 连接 OpenClaw 与蓝信企业即时通讯平台。",
      "order": 80,
      "aliases": [
        "lansenger",
        "lx"
      ],
      "markdownCapable": true,
      "exposure": {
        "configured": true,
        "setup": true,
        "docs": true
      },
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@lansenger-pm/openclaw-lansenger-channel@3.13.2",
      "localPath": ".",
      "defaultChoice": "npm"
    },
    "channelEnvVars": [
      {
        "name": "LANSENGER_APP_ID",
        "description": "Lansenger bot App ID (from Contacts → Smart Bot → Personal Bot)",
        "sensitive": false
      },
      {
        "name": "LANSENGER_APP_SECRET",
        "description": "Lansenger bot App Secret",
        "sensitive": true
      },
      {
        "name": "LANSENGER_API_GATEWAY_URL",
        "description": "Lansenger API Gateway URL (default: https://open.e.lanxin.cn/open/apigw)",
        "sensitive": false
      }
    ],
    "contracts": {
      "tools": [
        "lansenger_send_file",
        "lansenger_send_text",
        "lansenger_send_format_text",
        "lansenger_send_image_url",
        "lansenger_revoke_message",
        "lansenger_send_link_card",
        "lansenger_send_app_articles",
        "lansenger_send_app_card",
        "lansenger_update_dynamic_card",
        "lansenger_query_groups"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/ws": "^8.18.1",
    "openclaw": "^2026.6.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
